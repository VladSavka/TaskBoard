#!/usr/bin/env bash
# APS gherkin-parser wrapper. Delegates to the freshly installed APS Babashka
# tool under .aps so acceptance runs never reimplement the parser.
set -euo pipefail
here="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
root="$(cd "$here/../.." && pwd)"
exec bb --config "$root/.aps/bb.edn" gherkin-parser "$@"
