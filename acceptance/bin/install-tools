#!/usr/bin/env bash
# Install the external APS acceptance tools fresh from GitHub. These are not
# vendored into the repo; run this once per checkout before the acceptance
# pipeline is used. See swarmforge engineering rules: prefer a fresh install
# over stale vendored copies.
set -euo pipefail
here="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
root="$(cd "$here/../.." && pwd)"

clone_fresh() {
  local url="$1" dir="$2"
  rm -rf "$root/$dir"
  git clone --depth 1 "$url" "$root/$dir"
}

clone_fresh https://github.com/unclebob/Acceptance-Pipeline-Specification .aps
clone_fresh https://github.com/unclebob/speclj-structure-check .speclj-structure-check

echo "Installed APS ($(git -C "$root/.aps" rev-parse --short HEAD)) and speclj-structure-check ($(git -C "$root/.speclj-structure-check" rev-parse --short HEAD))."
